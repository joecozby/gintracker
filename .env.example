# ─── Database ───────────────────────────────────────────────────────────────
# MySQL connection string — required
# Local:     mysql://user:password@localhost:3306/gintracker
# PlanetScale: mysql://user:password@aws.connect.psdb.cloud/gintracker?ssl={"rejectUnauthorized":true}
# Railway:   provided automatically via $DATABASE_URL variable
DATABASE_URL=mysql://user:password@localhost:3306/gintracker

# ─── AI Insights ────────────────────────────────────────────────────────────
# Anthropic API key for the AI Insights feature (Claude 3.5 Sonnet)
# Get one at https://console.anthropic.com/
# Optional — if omitted, AI Insights will return a fallback message
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ─────────────────────────────────────────────────────────────────
# Port to listen on (default: 3000)
PORT=3000

# Set to "production" when deploying
NODE_ENV=production
